---
import Base from "../../layouts/Base.astro";
import BackLink from "../../components/BackLink.astro";
import WorkshopHero from "../../components/WorkshopHero.astro";
import TocRail from "../../components/TocRail.astro";
import ProgressRuler from "../../components/ProgressRuler.astro";
import Footer from "../../components/Footer.astro";
import { loadContent } from "../../lib/load-content";
import { renderWorkshop } from "../../lib/render-workshop";
import { slugify, stripNumericPrefix, shortName } from "../../lib/slugify";

export async function getStaticPaths() {
	const { hierarchy } = loadContent();
	return hierarchy.workshops.map((w) => {
		const title =
			w.title ?? stripNumericPrefix(shortName(w.filename));
		return {
			params: { workshop: slugify(title) },
			props: { workshopFilename: w.filename },
		};
	});
}

const { workshopFilename } = Astro.props as { workshopFilename: string };
const { hierarchy } = loadContent();
const workshop = hierarchy.byFilename.get(workshopFilename)!;
const title =
	workshop.title ??
	stripNumericPrefix(shortName(workshop.filename));
const rendered = await renderWorkshop(workshop, hierarchy);
---

<Base title={`${title} — Spark`}>
	<section class="ws-page">
		<BackLink href="/" label="Workshops" />
		<WorkshopHero
			title={title}
			authors={workshop.authors}
			date={workshop.date}
			pageCount={rendered.pageCount}
			wordCount={rendered.wordCount}
			cover={workshop.cover}
		/>
		<div class="ws-body">
			<TocRail items={rendered.toc} />
			<article class="prose" set:html={rendered.html} />
		</div>
	</section>
	<ProgressRuler items={rendered.toc} />
	<Footer />
</Base>

<style>
	.ws-page {
		max-width: 1400px;
		margin: 0 auto;
		padding: 16px;
	}
	@media (min-width: 640px) {
		.ws-page {
			padding: 32px;
		}
	}
	.ws-body {
		display: grid;
		grid-template-columns: 1fr;
		margin-top: 48px;
	}
	@media (min-width: 1024px) {
		.ws-body {
			grid-template-columns: 220px minmax(0, 1fr);
			gap: 64px;
		}
	}
	.prose {
		max-width: var(--content-w);
		overflow-wrap: break-word;
		min-width: 0;
	}
	.prose :global(.table-wrap) {
		overflow-x: auto;
		margin: 24px 0;
	}
	.prose :global(.table-wrap table) {
		margin: 0;
	}
	.prose :global(h1) {
		font-family: var(--serif);
		font-size: 34px;
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: -0.01em;
		margin-top: 64px;
		margin-bottom: 20px;
	}
	.prose :global(h2.chapter-divider) {
		font-family: var(--mono);
		font-size: 20px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-top: 80px;
		margin-bottom: 24px;
		color: var(--fg);
		text-align: center;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		gap: 24px;
		align-items: center;
	}
	.prose :global(h2.chapter-divider)::before,
	.prose :global(h2.chapter-divider)::after {
		content: "";
		height: 16px;
		background-image: var(--texture);
		background-repeat: repeat;
	}
	.prose :global(h2:not(.chapter-divider)) {
		font-family: var(--serif);
		font-size: 26px;
		font-weight: 600;
		line-height: 1.15;
		letter-spacing: -0.005em;
		margin-top: 48px;
		margin-bottom: 16px;
	}
	.prose :global(h3) {
		font-family: var(--serif);
		font-size: 20px;
		font-weight: 600;
		margin-top: 32px;
		margin-bottom: 12px;
		line-height: 1.2;
		letter-spacing: -0.005em;
	}
	.prose :global(p) {
		margin: 16px 0;
	}
	.prose :global(ul),
	.prose :global(ol) {
		margin: 16px 0;
		padding-left: 24px;
	}
	.prose :global(li) {
		margin: 8px 0;
	}
	.prose :global(.broken) {
		color: var(--muted);
		text-decoration: line-through;
	}
	.prose :global(code) {
		font-family: var(--mono);
		font-size: 13px;
		background: color-mix(in oklab, var(--fg) 8%, transparent);
		padding: 1px 5px;
		border-radius: 2px;
	}
	.prose :global(pre) {
		background: color-mix(in oklab, var(--fg) 6%, transparent);
		border: 1px solid var(--rule);
		padding: 14px 16px;
		overflow-x: auto;
		font-family: var(--mono);
		font-size: 12.5px;
		line-height: 1.6;
		margin: 24px 0;
	}
	.prose :global(pre code) {
		background: transparent;
		padding: 0;
		font-size: inherit;
	}
	.prose :global(table) {
		border-collapse: collapse;
		margin: 24px 0;
		width: 100%;
		font-size: 14px;
	}
	.prose :global(th),
	.prose :global(td) {
		padding: 8px 12px;
		text-align: left;
		border-bottom: 1px solid var(--rule);
	}
	.prose :global(th) {
		font-family: var(--mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted);
		border-bottom-width: 2px;
	}
	.prose :global(figure.md-figure) {
		margin: 32px auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 10px;
	}
	.prose :global(figure.md-figure .md-img-frame) {
		display: inline-block;
		max-width: 100%;
		padding: 12px;
		border: 1px solid var(--rule);
		background-image: var(--texture);
		background-repeat: repeat;
		line-height: 0;
		box-sizing: content-box;
	}
	.prose :global(figure.md-figure .md-img-frame img) {
		display: block;
		max-width: 100%;
		height: auto;
	}
	.prose :global(figure.md-figure figcaption) {
		font-family: var(--mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted);
		text-align: center;
		max-width: 90%;
	}
	.prose :global(img) {
		max-width: 100%;
		height: auto;
	}
</style>
