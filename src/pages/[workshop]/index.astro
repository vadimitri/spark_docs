---
import Base from "../../layouts/Base.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import BackLink from "../../components/BackLink.astro";
import WorkshopHero from "../../components/WorkshopHero.astro";
import TocRail from "../../components/TocRail.astro";
import ProgressRuler from "../../components/ProgressRuler.astro";
import Footer from "../../components/Footer.astro";
import { loadContent } from "../../lib/load-content";
import { renderWorkshop } from "../../lib/render-workshop";
import { slugify, stripNumericPrefix } from "../../lib/slugify";

export async function getStaticPaths() {
  const { hierarchy } = loadContent();
  return hierarchy.workshops.map((w) => {
    const title = w.title ?? stripNumericPrefix(w.filename.replace(/\.md$/, ""));
    return { params: { workshop: slugify(title) }, props: { workshopFilename: w.filename } };
  });
}

const { workshopFilename } = Astro.props as { workshopFilename: string };
const { hierarchy } = loadContent();
const workshop = hierarchy.byFilename.get(workshopFilename)!;
const title = workshop.title ?? stripNumericPrefix(workshop.filename.replace(/\.md$/, ""));
const rendered = await renderWorkshop(workshop, hierarchy);
---
<Base title={`${title} — Spark`}>
  <ThemeToggle />
  <section class="ws-page">
    <BackLink href="/" label="Workshops" />
    <WorkshopHero
      title={title}
      authors={workshop.authors}
      date={workshop.date}
      pageCount={rendered.pageCount}
      wordCount={rendered.wordCount}
      cover={workshop.cover}
    />
    <div class="ws-body">
      <TocRail items={rendered.toc} />
      <article class="prose" set:html={rendered.html}></article>
    </div>
    <ProgressRuler items={rendered.toc} />
  </section>
  <Footer />
</Base>

<style>
  .ws-page { max-width: 1400px; margin: 0 auto; padding: 32px; }
  .ws-body {
    display: grid; grid-template-columns: 1fr; margin-top: 48px;
  }
  @media (min-width: 1024px) {
    .ws-body { grid-template-columns: 220px minmax(0, 1fr); gap: 64px; }
  }
  .prose { max-width: var(--content-w); }
  .prose :global(h2) {
    font-family: var(--mono); font-size: 14px; text-transform: uppercase; letter-spacing: 0.08em;
    margin-top: 80px; margin-bottom: 24px; color: var(--fg);
    text-align: center;
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 16px; align-items: center;
  }
  .prose :global(h2)::before, .prose :global(h2)::after {
    content: ""; height: 8px; background-image: var(--texture); background-repeat: repeat;
  }
  .prose :global(h3) {
    font-family: var(--serif); font-size: 26px; font-weight: 600;
    margin-top: 48px; margin-bottom: 16px; line-height: 1.2; letter-spacing: -0.01em;
  }
  .prose :global(p) { margin: 16px 0; }
  .prose :global(ul), .prose :global(ol) { margin: 16px 0; padding-left: 24px; }
  .prose :global(li) { margin: 8px 0; }
  .prose :global(.broken) { color: var(--muted); text-decoration: line-through; }
  .prose :global(code) {
    font-family: var(--mono); font-size: 13px;
    background: color-mix(in oklab, var(--fg) 8%, transparent);
    padding: 1px 5px; border-radius: 2px;
  }
  .prose :global(pre) {
    background: color-mix(in oklab, var(--fg) 6%, transparent);
    border: 1px solid var(--rule);
    padding: 14px 16px; overflow-x: auto;
    font-family: var(--mono); font-size: 12.5px; line-height: 1.6;
    margin: 24px 0;
  }
  .prose :global(pre code) { background: transparent; padding: 0; font-size: inherit; }
  .prose :global(table) { border-collapse: collapse; margin: 24px 0; width: 100%; font-size: 14px; }
  .prose :global(th), .prose :global(td) { padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--rule); }
  .prose :global(th) {
    font-family: var(--mono); font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--muted); border-bottom-width: 2px;
  }
  .prose :global(img) { max-width: 100%; height: auto; }
</style>
