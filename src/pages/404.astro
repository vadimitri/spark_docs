---
import Base from "../layouts/Base.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import Footer from "../components/Footer.astro";
---
<Base title="Not found — Spark">
  <ThemeToggle />
  <main class="nf">
    <span class="label">404</span>
    <h1>Page not found.</h1>
    <p>That URL doesn't match any workshop or sub-page.</p>
    <p><a href="/">← Back to workshops</a></p>
  </main>
  <Footer />
</Base>

<style>
  .nf { max-width: 720px; margin: 0 auto; padding: 25vh 32px 32px; }
  .nf h1 { font-family: var(--serif); font-size: 48px; font-weight: 600; margin: 16px 0; letter-spacing: -0.015em; }
</style>
