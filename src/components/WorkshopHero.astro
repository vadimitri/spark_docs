---
interface Props {
  title: string;
  authors?: string[];
  date?: string;
  pageCount: number;
  wordCount: number;
  cover?: string;
}
const { title, authors, date, pageCount, wordCount, cover } = Astro.props;
const minutes = Math.max(1, Math.round(wordCount / 230));
const wordsK = (wordCount / 1000).toFixed(1);
const formattedDate = date?.replaceAll("-", "·");
---
<section class="ws-page-hero">
  <div>
    <h1>{title}</h1>
    <div class="meta">
      {authors?.length ? <span><strong>By</strong> {authors.join(" · ")}</span> : null}
      {formattedDate ? <span><strong>Updated</strong> {formattedDate}</span> : null}
      <span><strong>{pageCount} pages</strong> · {wordsK}k words · {minutes} min read</span>
    </div>
  </div>
  <div class="ws-cover-large">
    {cover ? <img src={cover} alt="" /> : <span class="placeholder">cover image · 4:3</span>}
  </div>
</section>

<style>
  .ws-page-hero {
    display: grid; gap: 48px;
    min-height: 60vh;
    padding: 80px 0;
    border-bottom: 1px solid var(--rule);
    align-items: end;
  }
  @media (min-width: 1024px) {
    .ws-page-hero { grid-template-columns: 1fr 1fr; gap: 6%; padding: 96px 0; }
  }
  .ws-page-hero h1 {
    font-family: var(--serif); font-size: 72px; font-weight: 600;
    line-height: 1.02; letter-spacing: -0.02em; margin: 0;
  }
  .meta {
    display: grid; gap: 6px; margin-top: 24px;
    font-family: var(--mono); font-size: 12px;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted);
  }
  .meta strong { color: var(--fg); font-weight: 500; }

  .ws-cover-large {
    background-image: var(--texture); background-repeat: repeat;
    border: 1px solid var(--rule);
    aspect-ratio: 4 / 3;
    display: grid; place-items: center; overflow: hidden;
  }
  .ws-cover-large img { width: 100%; height: 100%; object-fit: cover; }
  .ws-cover-large .placeholder { font-family: var(--mono); font-size: 11px; text-transform: uppercase; color: var(--muted); }
</style>
