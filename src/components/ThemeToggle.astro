<button id="theme-toggle" aria-label="Toggle color theme">Theme: system</button>

<style>
  #theme-toggle {
    position: fixed; top: 16px; right: 16px; z-index: 50;
    font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;
    background: transparent; color: var(--fg); border: 1px solid var(--fg);
    padding: 4px 10px; cursor: pointer;
  }
  #theme-toggle:hover { background: var(--fg); color: var(--bg); }
</style>

<script>
  const order = ["system", "light", "dark"] as const;
  type Mode = typeof order[number];

  const root = document.documentElement;
  const btn = document.getElementById("theme-toggle")!;

  function read(): Mode {
    const v = localStorage.getItem("spark-theme");
    return (order as readonly string[]).includes(v ?? "") ? (v as Mode) : "system";
  }
  function apply(m: Mode) {
    if (m === "system") root.removeAttribute("data-theme");
    else root.setAttribute("data-theme", m);
    btn.textContent = `Theme: ${m}`;
    localStorage.setItem("spark-theme", m);
  }

  let current = read();
  apply(current);
  btn.addEventListener("click", () => {
    current = order[(order.indexOf(current) + 1) % order.length];
    apply(current);
  });
</script>
