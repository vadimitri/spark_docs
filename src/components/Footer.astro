---

---

<footer>
	<span class="brand">
		<button
			id="theme-toggle"
			class="edit"
			type="button"
			aria-label="Toggle color theme">theme: system</button
		>
		<button
			id="theme-edit-btn"
			class="edit"
			type="button"
			aria-controls="theme-edit-panel"
			aria-label="Edit colors">edit</button
		>
	</span>
	<div class="center"></div>
	<span>VS</span>
</footer>

<div id="theme-edit-panel" role="dialog" aria-label="Color editor" hidden>
	<div class="head">
		<span class="title"
			>Colors · <span id="clr-theme-label">light</span></span
		>
		<button id="clr-close" type="button" aria-label="Close">×</button>
	</div>
	<div class="row">
		<label for="clr-bg-text">Background</label>
		<input id="clr-bg-swatch" data-var="bg" type="color" />
		<input
			id="clr-bg-text"
			data-var="bg"
			type="text"
			spellcheck="false"
			maxlength="7"
			placeholder="#9EC8FF"
		/>
	</div>
	<div class="row">
		<label for="clr-fg-text">Foreground</label>
		<input id="clr-fg-swatch" data-var="fg" type="color" />
		<input
			id="clr-fg-text"
			data-var="fg"
			type="text"
			spellcheck="false"
			maxlength="7"
			placeholder="#0E003B"
		/>
	</div>
	<div class="row">
		<label for="clr-link-text">Link</label>
		<input id="clr-link-swatch" data-var="link" type="color" />
		<input
			id="clr-link-text"
			data-var="link"
			type="text"
			spellcheck="false"
			maxlength="7"
			placeholder="#240195"
		/>
	</div>
	<div class="actions">
		<button id="clr-reset" type="button">Reset this theme</button>
		<span class="hint">Saved to this browser</span>
	</div>
</div>

<style>
	footer {
		max-width: 1400px;
		margin: 96px auto 0;
		padding: 32px;
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: 16px;
		align-items: center;
		font-family: var(--mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted);
	}
	footer .center {
		background-image: var(--texture);
		background-repeat: repeat;
		height: 8px;
	}
	footer .brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
	}
	footer .edit {
		font-family: var(--mono);
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted);
		background: transparent;
		border: 1px solid var(--rule);
		padding: 2px 6px;
		cursor: pointer;
	}
	footer .edit:hover {
		color: var(--fg);
		border-color: var(--fg);
	}

	#theme-edit-panel {
		position: fixed;
		left: 16px;
		bottom: 64px;
		z-index: 60;
		width: 280px;
		padding: 14px;
		background: var(--bg);
		color: var(--fg);
		border: 1px solid var(--fg);
		font-family: var(--mono);
		font-size: 12px;
		box-shadow: 4px 4px 0 var(--fg);
	}
	#theme-edit-panel[hidden] {
		display: none;
	}
	#theme-edit-panel .head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 12px;
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	#theme-edit-panel .head button {
		background: transparent;
		border: none;
		color: var(--fg);
		font-size: 18px;
		line-height: 1;
		cursor: pointer;
		padding: 0 4px;
	}
	#theme-edit-panel .row {
		display: grid;
		grid-template-columns: 90px 28px 1fr;
		gap: 8px;
		align-items: center;
		margin: 6px 0;
	}
	#theme-edit-panel label {
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted);
	}
	#theme-edit-panel input[type="color"] {
		width: 28px;
		height: 24px;
		padding: 0;
		border: 1px solid var(--rule);
		background: transparent;
		cursor: pointer;
	}
	#theme-edit-panel input[type="text"] {
		font-family: var(--mono);
		font-size: 12px;
		background: transparent;
		color: var(--fg);
		border: 1px solid var(--rule);
		padding: 3px 6px;
		width: 100%;
	}
	#theme-edit-panel input[type="text"]:focus {
		outline: none;
		border-color: var(--fg);
	}
	#theme-edit-panel input.invalid {
		border-color: #c0392b;
	}
	#theme-edit-panel .actions {
		margin-top: 12px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
	}
	#theme-edit-panel #clr-reset {
		font-family: var(--mono);
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		background: transparent;
		color: var(--fg);
		border: 1px solid var(--fg);
		padding: 3px 8px;
		cursor: pointer;
	}
	#theme-edit-panel #clr-reset:hover {
		background: var(--fg);
		color: var(--bg);
	}
	#theme-edit-panel .hint {
		font-size: 10px;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
</style>

<script>
	const VARS = ["bg", "fg", "link"] as const;
	type Var = (typeof VARS)[number];
	type Theme = "light" | "dark";

	const root = document.documentElement;
	const btn = document.getElementById("theme-edit-btn") as HTMLButtonElement;
	const panel = document.getElementById("theme-edit-panel") as HTMLDivElement;
	const closeBtn = document.getElementById("clr-close") as HTMLButtonElement;
	const resetBtn = document.getElementById("clr-reset") as HTMLButtonElement;
	const themeLabel = document.getElementById(
		"clr-theme-label",
	) as HTMLSpanElement;

	const HEX = /^#([0-9a-f]{3}|[0-9a-f]{6})$/i;

	function activeTheme(): Theme {
		const d = root.dataset.theme;
		if (d === "light" || d === "dark") return d;
		return matchMedia("(prefers-color-scheme: dark)").matches
			? "dark"
			: "light";
	}
	function key(t: Theme) {
		return `spark-colors-${t}`;
	}
	function readOverrides(t: Theme): Partial<Record<Var, string>> {
		try {
			const r = localStorage.getItem(key(t));
			return r ? JSON.parse(r) : {};
		} catch {
			return {};
		}
	}
	function writeOverrides(t: Theme, v: Partial<Record<Var, string>>) {
		try {
			if (Object.keys(v).length === 0) localStorage.removeItem(key(t));
			else localStorage.setItem(key(t), JSON.stringify(v));
		} catch {}
	}
	function applyOverrides(v: Partial<Record<Var, string>>) {
		for (const k of VARS) {
			const val = v[k];
			if (val) root.style.setProperty(`--${k}`, val);
			else root.style.removeProperty(`--${k}`);
		}
	}
	function currentComputed(k: Var): string {
		const s = getComputedStyle(root).getPropertyValue(`--${k}`).trim();
		return normalizeToHex(s);
	}
	function normalizeToHex(input: string): string {
		if (!input) return "#000000";
		if (HEX.test(input)) {
			if (input.length === 4) {
				return (
					"#" +
					input
						.slice(1)
						.split("")
						.map((c) => c + c)
						.join("")
				).toLowerCase();
			}
			return input.toLowerCase();
		}
		const m = input.match(/rgba?\(([^)]+)\)/i);
		if (m) {
			const [r, g, b] = m[1].split(/[,\s/]+/).map(Number);
			const h = (n: number) =>
				Math.max(0, Math.min(255, Math.round(n)))
					.toString(16)
					.padStart(2, "0");
			return `#${h(r)}${h(g)}${h(b)}`;
		}
		return "#000000";
	}

	function populateInputs() {
		const t = activeTheme();
		themeLabel.textContent = t;
		const saved = readOverrides(t);
		for (const k of VARS) {
			const swatch = document.getElementById(
				`clr-${k}-swatch`,
			) as HTMLInputElement;
			const text = document.getElementById(
				`clr-${k}-text`,
			) as HTMLInputElement;
			const value = saved[k] ?? currentComputed(k);
			swatch.value = value;
			text.value = value;
			text.classList.remove("invalid");
		}
	}

	function setVar(k: Var, value: string) {
		const t = activeTheme();
		const saved = readOverrides(t);
		saved[k] = value;
		writeOverrides(t, saved);
		applyOverrides(saved);
	}

	// Inputs
	for (const k of VARS) {
		const swatch = document.getElementById(
			`clr-${k}-swatch`,
		) as HTMLInputElement;
		const text = document.getElementById(
			`clr-${k}-text`,
		) as HTMLInputElement;

		swatch.addEventListener("input", () => {
			text.value = swatch.value;
			text.classList.remove("invalid");
			setVar(k, swatch.value);
		});
		text.addEventListener("input", () => {
			const v = text.value.trim();
			if (HEX.test(v)) {
				text.classList.remove("invalid");
				const norm = normalizeToHex(v);
				swatch.value = norm;
				setVar(k, norm);
			} else {
				text.classList.add("invalid");
			}
		});
	}

	// Open / close
	function open() {
		populateInputs();
		panel.hidden = false;
		btn.setAttribute("aria-expanded", "true");
	}
	function close() {
		panel.hidden = true;
		btn.setAttribute("aria-expanded", "false");
	}
	btn.addEventListener("click", () => (panel.hidden ? open() : close()));
	closeBtn.addEventListener("click", close);
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape" && !panel.hidden) close();
	});

	// Reset current theme
	resetBtn.addEventListener("click", () => {
		const t = activeTheme();
		writeOverrides(t, {});
		applyOverrides({});
		populateInputs();
	});

	// React to theme changes from ThemeToggle (data-theme attr flips) — re-apply correct set
	new MutationObserver(() => {
		applyOverrides(readOverrides(activeTheme()));
		if (!panel.hidden) populateInputs();
	}).observe(root, { attributes: true, attributeFilter: ["data-theme"] });

	// React to OS theme change when mode is "system"
	matchMedia("(prefers-color-scheme: dark)").addEventListener(
		"change",
		() => {
			if (root.dataset.theme) return; // explicit theme wins
			applyOverrides(readOverrides(activeTheme()));
			if (!panel.hidden) populateInputs();
		},
	);

	// Theme cycle button (sits next to the edit pill)
	const themeOrder = ["system", "light", "dark"] as const;
	type ThemeMode = (typeof themeOrder)[number];
	const themeBtn = document.getElementById(
		"theme-toggle",
	) as HTMLButtonElement;

	function readThemeMode(): ThemeMode {
		const v = localStorage.getItem("spark-theme");
		return (themeOrder as readonly string[]).includes(v ?? "")
			? (v as ThemeMode)
			: "system";
	}
	function applyThemeMode(m: ThemeMode) {
		if (m === "system") root.removeAttribute("data-theme");
		else root.setAttribute("data-theme", m);
		themeBtn.textContent = `theme: ${m}`;
		try {
			localStorage.setItem("spark-theme", m);
		} catch {}
	}
	let currentMode = readThemeMode();
	applyThemeMode(currentMode);
	themeBtn.addEventListener("click", () => {
		currentMode =
			themeOrder[
				(themeOrder.indexOf(currentMode) + 1) % themeOrder.length
			];
		applyThemeMode(currentMode);
	});
</script>
