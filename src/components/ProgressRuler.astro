---
// Headless: renders no UI; just drives .toc li.active via IntersectionObserver.
---

<script>
  // Drives .toc li.active based on the heading currently in view.
  const headings = Array.from(
    document.querySelectorAll<HTMLElement>(
      ".prose h1[id], .prose h2[id], .prose h3[id]"
    )
  );
  if (headings.length > 0) {
    const tocLinks = new Map<string, HTMLElement>();
    document
      .querySelectorAll<HTMLElement>("[data-toc-link]")
      .forEach((el) => tocLinks.set(el.dataset.tocLink!, el));

    // Map every heading id → the id of the chapter-divider that contains it
    // (the most recent chapter-divider in DOM order). Used to keep the chapter
    // TOC entry highlighted while scrolling through that chapter's contents.
    const headingToChapter = new Map<string, string>();
    let runningChapter: string | null = null;
    headings.forEach((h) => {
      if (h.classList.contains("chapter-divider")) runningChapter = h.id;
      if (runningChapter) headingToChapter.set(h.id, runningChapter);
    });

    let activeId: string | null = null;
    let activeChapter: string | null = null;

    function setActive(id: string | null) {
      if (activeId === id) return;
      if (activeId) tocLinks.get(activeId)?.parentElement?.classList.remove("active");
      activeId = id;
      if (id) tocLinks.get(id)?.parentElement?.classList.add("active");

      const newChapter = id ? headingToChapter.get(id) ?? null : null;
      if (newChapter !== activeChapter) {
        if (activeChapter) tocLinks.get(activeChapter)?.parentElement?.classList.remove("in-chapter");
        activeChapter = newChapter;
        if (activeChapter) tocLinks.get(activeChapter)?.parentElement?.classList.add("in-chapter");
      }
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible.length > 0) {
          setActive((visible[0].target as HTMLElement).id);
        }
      },
      { rootMargin: "0px 0px -75% 0px", threshold: 0 }
    );
    headings.forEach((h) => observer.observe(h));
  }
</script>
