---
interface Props { caption?: string; figNum?: string }
const { caption, figNum } = Astro.props;
---
<figure>
  <span class="b-l"></span><span class="b-r"></span>
  <slot />
  {(caption || figNum) && (
    <>
      {figNum && <figcaption class="num">FIG_{figNum}</figcaption>}
      {caption && <figcaption class="cap">[{caption}]</figcaption>}
    </>
  )}
</figure>

<style>
  figure {
    position: relative; margin: 32px 0;
    background-image: var(--texture); background-repeat: repeat;
    padding: 32px 24px 40px;
    display: grid; place-items: center; gap: 16px;
  }
  figure::before, figure::after,
  figure > .b-l, figure > .b-r {
    content: ""; position: absolute;
    background-image: var(--texture); background-repeat: repeat;
  }
  figure::before { top: 0; left: 0; right: 0; height: 2px; }
  figure::after { bottom: 0; left: 0; right: 0; height: 2px; }
  figure > .b-l { top: 0; bottom: 0; left: 0; width: 2px; }
  figure > .b-r { top: 0; bottom: 0; right: 0; width: 2px; }
  figure :global(img) { max-width: 100%; height: auto; }
  figcaption.num {
    position: absolute; top: 6px; left: 14px;
    transform-origin: top left; transform: rotate(90deg);
    background: var(--bg); padding: 0 4px;
    font-family: var(--mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted);
  }
  figcaption.cap {
    font-family: var(--mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted);
    margin-top: 4px;
  }
</style>
