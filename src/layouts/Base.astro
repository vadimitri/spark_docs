---
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Spark — HPI maker club workshops." } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <script is:inline>
    // Apply persisted theme before paint to avoid flash
    try {
      const t = localStorage.getItem("spark-theme");
      if (t === "light" || t === "dark") document.documentElement.dataset.theme = t;
    } catch (_) {}
  </script>
</head>
<body>
  <slot />
</body>
</html>
